# ======================== Server ========================
HOST=127.0.0.1
PORT=8082

# Server API key (Anthropic-style).
# Leave empty only when HOST/port binding is localhost-only.
# Docker Compose refuses to start until this is set because it binds inside the
# container on 0.0.0.0 and may be exposed by the host port mapping.
ANTHROPIC_AUTH_TOKEN=

# Docker host bind address. Defaults to localhost for fail-closed deployments.
# Set to 0.0.0.0 only after setting ANTHROPIC_AUTH_TOKEN to a strong secret.
CRUSTOXY_LISTEN_ADDR=127.0.0.1

# Cloudflare WARP is disabled by default. Use the compose "warp" profile to
# grant NET_ADMIN and /dev/net/tun, which also sets CRUSTOXY_ENABLE_WARP=true.
CRUSTOXY_ENABLE_WARP=false

# ======================== Logging ========================
# Set RUST_LOG for log level: trace, debug, info, warn, error
RUST_LOG=info

# ========================================================
# NOTE: All proxy configuration (models, API keys, routing, features) is
# managed by the Web UI/panel and stored persistently in the single source:
# ~/.config/crustoxy/config.toml
