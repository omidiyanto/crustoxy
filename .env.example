# ======================== Server ========================
HOST=0.0.0.0
PORT=8082

# Optional server API key (Anthropic-style). Leave empty for no auth.
ANTHROPIC_AUTH_TOKEN=

# ======================== Model Mapping ========================
# Format: provider_name/model_name
# All Claude model requests are mapped to these models
MODEL=openrouter/meta-llama/llama-3-8b-instruct:free
MODEL_OPUS=openai/gpt-4o
MODEL_SONNET=openrouter/meta-llama/llama-3-8b-instruct:free
MODEL_HAIKU=groq/llama3-8b-8192

# ======================== Rate Limiting ========================
# Defines how many requests are allowed per sliding window
PROVIDER_RATE_LIMIT=40
# The window duration in seconds
PROVIDER_RATE_WINDOW=60
# Caps simultaneous active requests sent to backend API
PROVIDER_MAX_CONCURRENCY=5

# ======================== HTTP Timeouts ========================
HTTP_READ_TIMEOUT=300
HTTP_CONNECT_TIMEOUT=10

# ======================== IP Rotation (WARP) ========================
# When receiving a 429 error, triggers warp-cli to rotate Cloudflare WARP IP
ENABLE_IP_ROTATION=true

# ======================== Optimizations & Safety Nets ========================
# Mocks Claude's network test to save API calls
ENABLE_NETWORK_PROBE_MOCK=true
# Skips background title generation for conversations
ENABLE_TITLE_GENERATION_SKIP=true
# Mocks suggestion queries
ENABLE_SUGGESTION_MODE_SKIP=true
# Accelerates chunk prefix parsing
FAST_PREFIX_DETECTION=true
# Mocks intensive OS filepath extraction searches
ENABLE_FILEPATH_EXTRACTION_MOCK=true

# --- Auto-Retry Pipeline ---
# Retries queries silently when open-source models fail to yield structured tool JSON
ENABLE_TOOL_RETRY=true
# Maximum number of automated tool-calling retries per query
TOOL_RETRY_MAX=2

# ======================== Provider API Keys ========================
# Set the API key for each provider you want to use.
# Only the providers referenced in MODEL/MODEL_OPUS/MODEL_SONNET/MODEL_HAIKU need keys.

OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
TOGETHER_API_KEY=
HUGGINGFACE_API_KEY=
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=
KIMI_API_KEY=
ZHIPU_API_KEY=
ANYSCALE_API_KEY=
SILICONFLOW_API_KEY=
NOVITA_API_KEY=
NVIDIA_NIM_API_KEY=
MODAL_API_KEY=
OPENCODE_ZEN_API_KEY=

# ======================== Provider Base URL Overrides ========================
# Uncomment to override default base URLs for any provider.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# TOGETHER_BASE_URL=https://api.together.xyz/v1
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# PERPLEXITY_BASE_URL=https://api.perplexity.ai
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ANYSCALE_BASE_URL=https://api.endpoints.anyscale.com/v1
# SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
# NOVITA_BASE_URL=https://api.novita.ai/openai
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# MODAL_BASE_URL=https://api.modal.com/v1
# OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# VLLM_BASE_URL=http://localhost:8000/v1
# LLAMACPP_BASE_URL=http://localhost:8080/v1
# CUSTOM_BASE_URL=http://localhost:9000/v1

# ======================== Logging ========================
# Set RUST_LOG for log level: trace, debug, info, warn, error
RUST_LOG=info
