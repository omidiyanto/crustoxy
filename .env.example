# ======================== Server ========================
HOST=0.0.0.0
PORT=8082

# Optional server API key (Anthropic-style). Leave empty for no auth.
ANTHROPIC_AUTH_TOKEN=

# ======================== Logging ========================
# Set RUST_LOG for log level: trace, debug, info, warn, error
RUST_LOG=info

# ========================================================
# NOTE: All other configurations (models, API keys, routing, features) 
# have been moved to the Web UI and are stored persistently in:
# ~/.config/crustoxy/config.toml
